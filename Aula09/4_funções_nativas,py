lista = [1,4,3,2,5,7,6]
palavra_gerenica = "banido"
num1 = 3
flutuante = 2.999

# quantidade de itens (funciona com strings)
print(len(lista))
# quantidade de caracteres
print(len(palavra_gerenica))

# soma todos os valores da lista (erro se tiver string)
print(sum(lista))

# retorna o maior valor
print(max(lista))

# retorna o menor valor
print(min(lista))

# ordena e apresenta a lista (nao altera a lista padrão)
print(sorted(lista))
print(lista)

# retorna o tipo do valor
print(type(lista))
print(type(palavra_gerenica))
print(type(num1))

# converter tipo
# inteiro para texto
num_str = str(num1)
# interio para flutuante
num_float = float(num1)
# flutuante para inteiro
num_int = int(flutuante)




